generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Patient {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  password  String
  phone     String
  createdAt DateTime @default(now())
}

model Doctor {
  id             Int      @id @default(autoincrement())
  firstName      String
  lastName       String
  email          String   @unique
  password       String
  phone          String
  specialisation String
  status         Status   @default(PENDING)

  // Profile fields (DAMS-20)
  profilePhoto    String?
  bio             String?
  qualifications  String?
  experience      String?
  consultationFee Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}